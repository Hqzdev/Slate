{
  "compilerOptions": {
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tmp/messenger-backfill",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "scripts/backfill-messenger.ts",
    "scripts/smoke-messenger-foundation.ts"
  ]
}
