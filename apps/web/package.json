{
  "name": "@slate/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "db:generate": "prisma generate && npm --prefix ../../services/sync run db:generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:push": "prisma db push",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.test.json && node --test .tmp/test-build/tests/**/*.test.js",
    "start": "node scripts/run-next.mjs start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.29.0",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "postcss": "8.5.16"
  }
}
