{
  "name": "@slate/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "db:generate": "prisma generate && npm --prefix ../../services/sync run db:generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:push": "prisma db push",
    "lint": "eslint .",
    "messenger:backfill": "tsc -p tsconfig.messenger-backfill.json && node .tmp/messenger-backfill/scripts/backfill-messenger.js",
    "messenger:attachments:cleanup": "tsc -p tsconfig.messenger-attachment-cleanup.json && node .tmp/messenger-attachment-cleanup/scripts/cleanup-messenger-attachments.js",
    "messenger:key:rotate": "tsc -p tsconfig.messenger-key-rotation.json && node .tmp/messenger-key-rotation/scripts/rotate-messenger-key.js",
    "messenger:direct-conversations:cleanup": "tsc -p tsconfig.messenger-direct-cleanup.json && node .tmp/messenger-direct-cleanup/scripts/cleanup-messenger-direct-conversations.js",
    "messenger:retention:cleanup": "tsc -p tsconfig.messenger-retention.json && node .tmp/messenger-retention/scripts/cleanup-messenger-retention.js",
    "messenger:media:smoke": "tsc -p tsconfig.messenger-media-smoke.json && node .tmp/messenger-media-smoke/scripts/smoke-messenger-media.js",
    "messenger:smoke": "tsc -p tsconfig.messenger-backfill.json && node .tmp/messenger-backfill/scripts/smoke-messenger-foundation.js",
    "messenger:storage:smoke": "tsc -p tsconfig.messenger-storage-smoke.json && node .tmp/messenger-storage-smoke/scripts/smoke-messenger-storage.js",
    "messenger:ai:worker": "tsc -p tsconfig.messenger-ai-worker.json && node .tmp/messenger-ai-worker/scripts/messenger-ai-worker.js",
    "messenger:load": "node scripts/load-messenger.mjs",
    "messenger:security:staging": "node scripts/security-messenger-staging.mjs",
    "test": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json && node --test .tmp/test-build/tests/**/*.test.js",
    "start": "node scripts/run-next.mjs start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.19.3",
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-presigned-post": "^3.883.0",
    "bullmq": "^5.79.2",
    "ioredis": "^5.11.1",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.29.0",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "postcss": "8.5.16"
  }
}
