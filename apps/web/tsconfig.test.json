{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tmp/test-build",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "lib/server/prisma.ts",
    "lib/server/auditLog.ts",
    "lib/server/clientIpAddress.ts",
    "lib/server/messenger/accessPolicy.ts",
    "lib/server/messenger/attachmentService.ts",
    "lib/server/messenger/attachmentAvailability.ts",
    "lib/server/messenger/attachmentCleanupService.ts",
    "lib/server/messenger/attachmentContentService.ts",
    "lib/server/messenger/availability.ts",
    "lib/server/messenger/cryptography.ts",
    "lib/server/messenger/errors.ts",
    "lib/server/messenger/input.ts",
    "lib/server/messenger/keyEnvelopeService.ts",
    "lib/server/messenger/mediaStreamRegistry.ts",
    "lib/server/messenger/outboxRepository.ts",
    "lib/server/messenger/objectStorage.ts",
    "lib/server/messenger/provisioningService.ts",
    "lib/server/messenger/realtimeConfiguration.ts",
    "lib/server/messenger/realtimeGrant.ts",
    "lib/server/messenger/retentionService.ts",
    "lib/server/messenger/repository.ts",
    "lib/client/messengerAttachmentPolicy.ts",
    "lib/client/messengerAttachmentUpload.ts",
    "lib/server/realtimeGrant.ts",
    "lib/server/notificationRepository.ts",
    "lib/server/workspaceAccessPolicy.ts",
    "lib/server/workspaceOwnershipPolicy.ts",
    "lib/server/workspaceInvitePolicy.ts",
    "tests/**/*.ts"
  ]
}
