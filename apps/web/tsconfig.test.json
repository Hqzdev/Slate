{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tmp/test-build",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "lib/server/prisma.ts",
    "lib/server/auditLog.ts",
    "lib/server/realtimeGrant.ts",
    "lib/server/workspaceAccessPolicy.ts",
    "lib/server/workspaceOwnershipPolicy.ts",
    "tests/**/*.ts"
  ]
}
